# Frontend environment variables
# Copy this file to .env.local (local development) or set these in your deployment platform (Netlify, Vercel, etc.)

# API Backend URL
# - For local development with backend on localhost:4000, leave unset (defaults to http://localhost:4000)
# - For production or remote backend, set to your backend URL
VITE_API_URL=https://folushovictory-backend.onrender.com
