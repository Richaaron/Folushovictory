{
  "name": "frontend-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "build:web": "vue-tsc -b && vite build",
    "build:android": "vue-tsc -b && vite build --mode android && npx cap sync",
    "build:apk": "call build-apk.bat",
    "build:electron": "npm run build:web && electron-builder --win",
    "build:exe": "npm run build:web && electron-builder --win --publish never",
    "electron:dev": "vite",
    "electron:start": "wait-on http://localhost:5173 && electron .",
    "start:electron": "concurrently npm:dev npm:electron:start",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:build": "npx cap build android"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "3.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8",
    "wait-on": "^8.0.0"
  }
}
