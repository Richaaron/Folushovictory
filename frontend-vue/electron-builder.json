{
  "appId": "com.folushovictory.app",
  "productName": "Folusho Victory",
  "directories": {
    "buildResources": "electron/assets",
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "electron/main.cjs",
    "electron/preload.cjs",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "icon": "electron/assets/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "certificateFile": "electron/assets/cert.pfx",
    "certificatePassword": "buildit2026",
    "certificateSubjectName": "Build IT",
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Folusho Victory"
  },
  "portable": {
    "artifactName": "Folusho-Victory-${version}.exe"
  }
}
