<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030206"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Results"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Publish results for a class"
            android:textColor="#94A3B8"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/inputPublishClassId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Class ID"
            android:inputType="text"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPublishClassName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Class name (optional)"
            android:inputType="textCapWords"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPublishSubjectId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Subject ID"
            android:inputType="text"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPublishSubjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Subject name (optional)"
            android:inputType="textCapWords"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPublishSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Session"
            android:inputType="text"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPublishTerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Term"
            android:inputType="text"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnPublishResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publish Results"
            android:background="#2563EB"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnEnterScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter Scores"
            android:background="#D4AF37"
            android:textColor="#000000"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnViewBroadsheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Broadsheet"
            android:background="#10B981"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnViewActivityLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity Logs"
            android:background="#6B21A8"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnManageRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin Remarks"
            android:background="#F97316"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnManageGradingScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure Grading Scale"
            android:background="#1D4ED8"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnManageAssignments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Assign Subjects to Teacher"
            android:background="#8B5CF6"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use the same Class ID as displayed under Classes. Published results are emailed to parents once the results are updated by the system."
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
