<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_bg_gradient">

    <TextView
        android:id="@+id/tvReportTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Term Report"
        android:textColor="@color/text_white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvReportSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2025/2026 • Second Term"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tvAverageGrade"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Average: A"
            android:textColor="@color/gold_main"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Released"
            android:textColor="@color/success"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Position: 1st"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

</LinearLayout>
