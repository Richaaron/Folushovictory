<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header with Session Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:layout_marginBottom="12dp" />

        <!-- Session Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academic Session"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvActiveSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025/2026"
                    android:textSize="16sp"
                    android:textColor="@color/gold_main"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/divider"
                android:layout_marginHorizontal="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Term"
                    android:textSize="10sp"
                    android:textColor="@color/text_tertiary"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCurrentTerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Second Term"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Refresh Button -->
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerInside"
                android:background="@drawable/button_circular_bg"
                android:src="@drawable/ic_refresh"
                android:contentDescription="Refresh"
                android:tint="@color/gold_main" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="16dp">

            <!-- System Alerts Banner -->
            <LinearLayout
                android:id="@+id/alertsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- System Health Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_bg_gradient"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SYSTEM HEALTH"
                        android:textSize="9sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.15"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHealthLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Operating Normally"
                        android:textSize="14sp"
                        android:textColor="@color/text_white"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/healthIndicator"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="84"
                    android:progressDrawable="@drawable/circular_progress"
                    android:indeterminate="false" />

            </LinearLayout>

            <!-- Stats Console Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Row 1: Students & Teachers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <!-- Students Card -->
                    <LinearLayout
                        android:id="@+id/cardStudents"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_admin"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STUDENTS"
                            android:textSize="8sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvStudentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="289"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/portal_admin"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Teachers Card -->
                    <LinearLayout
                        android:id="@+id/cardTeachers"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_teacher"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🏫"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FACULTY"
                            android:textSize="8sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvTeacherCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/portal_teacher"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Classes & Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Classes Card -->
                    <LinearLayout
                        android:id="@+id/cardClasses"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_class"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLASSES"
                            android:textSize="8sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvClassCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/gold_main"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Pending Card -->
                    <LinearLayout
                        android:id="@+id/cardPending"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/stat_card_pending"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱️"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENDING"
                            android:textSize="8sp"
                            android:textColor="@color/text_tertiary"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvPendingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Quick Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSystemConfig"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="System Config"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textColor="@color/text_white"
                    app:backgroundTint="@color/portal_admin"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDataMgmt"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Data Management"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textColor="@color/text_white"
                    app:backgroundTint="@color/button_primary"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Recent Activity Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </ScrollView>

    <!-- Loading Indicator -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#0F172A99">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/gold_main" />

    </FrameLayout>

</LinearLayout>
