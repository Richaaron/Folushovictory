<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Background Gradient Elements -->
    <View
        android:id="@+id/gradientBg1"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="@drawable/gradient_circle_purple"
        android:alpha="0.15" />

    <View
        android:id="@+id/gradientBg2"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:background="@drawable/gradient_circle_gold"
        android:alpha="0.1" />

    <!-- Loading Indicator -->
    <FrameLayout
        android:id="@+id/loadingIndicator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#0F172A99">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/gold_main" />
    </FrameLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingVertical="40dp">

            <!-- Welcome Section -->
            <LinearLayout
                android:id="@+id/welcomeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="60dp">

                <!-- App Logo / Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Folusho Victory"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_white"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School Management Portal"
                    android:textSize="14sp"
                    android:textColor="@color/gold_main"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp" />

                <!-- Tagline -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Unified Academic Engine"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select your role to access the portal and manage academic operations with precision and control."
                    android:textSize="13sp"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

            <!-- Portal Selection Container -->
            <LinearLayout
                android:id="@+id/landingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">

                <!-- Admin Portal Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAdminPortal"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/portal_admin"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡️"
                            android:textSize="32sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="For Administrators"
                            android:textSize="11sp"
                            android:textColor="@color/text_light_secondary"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Teacher Portal Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnTeacherPortal"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/portal_teacher"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="32sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="For Faculty Members"
                            android:textSize="11sp"
                            android:textColor="@color/text_light_secondary"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Parent Portal Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnParentPortal"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    app:cardBackgroundColor="@color/portal_parent"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👪"
                            android:textSize="32sp"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="For Parents &amp; Guardians"
                            android:textSize="11sp"
                            android:textColor="@color/text_light_secondary"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Footer Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="#111827CC">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 Folusho Victory Schools. All rights reserved."
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:gravity="center"
            android:letterSpacing="0.05" />

    </LinearLayout>

</RelativeLayout>
