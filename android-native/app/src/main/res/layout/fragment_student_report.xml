<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/reportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Report"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <ProgressBar
            android:id="@+id/reportProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <TextView
            android:id="@+id/reportError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark"
            android:visibility="gone"
            android:paddingTop="12dp" />

        <LinearLayout
            android:id="@+id/reportContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/reportStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/reportStudentClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Class"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/reportSessionTerm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Session / Term"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/reportAverage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Average"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/reportPosition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Position"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/reportStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status"
                android:paddingTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject Scores"
                android:textStyle="bold"
                android:paddingTop="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/subjectsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
