<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#030206"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBroadsheetHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Broadsheet"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnSortAvg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sort by Avg"
            android:layout_marginEnd="8dp"
            android:background="#374151"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSortTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sort by Total"
            android:layout_marginEnd="8dp"
            android:background="#374151"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Export CSV"
            android:background="#111827"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/hvHeaderSubjects"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/headerSubjects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <EditText
        android:id="@+id/inputBroadsheetClassId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Class ID"
        android:inputType="text"
        android:backgroundTint="#94A3B8"
        android:textColor="#FFFFFF"
        android:textColorHint="#94A3B8"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/inputBroadsheetSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Session"
        android:inputType="text"
        android:backgroundTint="#94A3B8"
        android:textColor="#FFFFFF"
        android:textColorHint="#94A3B8"
        android:padding="12dp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/inputBroadsheetTerm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Term"
        android:inputType="text"
        android:backgroundTint="#94A3B8"
        android:textColor="#FFFFFF"
        android:textColorHint="#94A3B8"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLoadBroadsheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Load Broadsheet"
        android:background="#4B5563"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBroadsheet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/broadsheetProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        style="?android:attr/progressBarStyleLarge" />

</LinearLayout>
