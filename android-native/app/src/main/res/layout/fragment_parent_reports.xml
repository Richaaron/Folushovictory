<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/parentReportsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report Card Center"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <ProgressBar
            android:id="@+id/parentReportsProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/parentReportsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student"
                android:textStyle="bold"
                android:paddingTop="12dp" />

            <TextView
                android:id="@+id/parentReportsStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/parentReportsStudentClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Class"
                android:paddingTop="4dp" />

            <Button
                android:id="@+id/buttonViewLatestReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Latest Report"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
