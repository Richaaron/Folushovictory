<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#030206">

    <EditText
        android:id="@+id/etClassId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Class ID"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Session (e.g. 2025/2026)"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etTerm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Term"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGenerate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generate Reports"
        android:backgroundTint="#D4AF37"
        android:textColor="#000000" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        style="?android:attr/progressBarStyleLarge"
        android:layout_marginTop="12dp" />
</LinearLayout>
