<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030206"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Remarks"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputRemarkStudentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Student ID"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/inputRemarkSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Session"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/inputRemarkTerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Term"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputTeacherRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Teacher remark"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSetTeacherRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Teacher Remark"
            android:background="#2563EB"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputPrincipalRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Principal remark"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:backgroundTint="#94A3B8"
            android:textColor="#FFFFFF"
            android:textColorHint="#94A3B8"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSetPrincipalRemark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Principal Remark"
            android:background="#111827"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>
